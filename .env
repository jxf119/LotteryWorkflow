# 大乐透预测系统环境变量配置

# 数据库配置
DATABASE_PATH=lottery_data.db
ERROR_LOG_DB=error_logs.db
SYSTEM_MONITOR_DB=system_monitor.db

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/lottery.log
ERROR_LOG_FILE=logs/error.log

# 数据采集配置
DATA_SOURCE_URL=https://datachart.500.com/dlt/history/
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# 通知服务配置
# Slack
SLACK_WEBHOOK_URL=
SLACK_ENABLED=false

# 飞书
FEISHU_WEBHOOK_URL=
FEISHU_ENABLED=false

# 邮件
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_ENABLED=false

# 系统监控
MONITOR_INTERVAL=3600
HEALTH_CHECK_INTERVAL=300